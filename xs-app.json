{
  "welcomeFile": "/index.html",
  "authenticationMethod": "route",
  "routes": [
    {
      "comment": "Service 1 - LIPS items from ECC. Maps /ecc/* to the ecc-backend destination.",
      "source": "^/ecc/(.*)$",
      "target": "/$1",
      "destination": "ecc-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": false
    },
    {
      "comment": "Service 2 + Service 3 - LIPS items from HANA and POST of missing items.",
      "source": "^/hana/(.*)$",
      "target": "/$1",
      "destination": "hana-backend",
      "authenticationType": "xsuaa",
      "csrfProtection": true
    },
    {
      "comment": "Static app content served from the HTML5 Application Repository.",
      "source": "^/(.*)$",
      "target": "/$1",
      "service": "html5-apps-repo-rt",
      "authenticationType": "xsuaa"
    }
  ]
}
