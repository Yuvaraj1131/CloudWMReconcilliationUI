<mvc:View
	controllerName="com.bluestonex.cloudwmreconcilliationui.controller.Reconciliation"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.f"
	xmlns:t="sap.ui.table"
	displayBlock="true"
	height="100%">

	<f:DynamicPage id="page" fitContent="true" showFooter="{= ${ui>/selectedTab} === 'MISSING' &amp;&amp; ${ui>/masterData} === 'DELIVERY_ITEM' }" busy="{ui>/busy}" busyIndicatorDelay="0">

		<!-- ============================ TITLE ============================ -->
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{i18n>appTitle}" />
				</f:heading>
				<f:actions>
					<ObjectStatus text="{i18n>statusEcc}: {ui>/eccCount}" state="Information" class="sapUiTinyMarginEnd" />
					<ObjectStatus text="{i18n>statusHana}: {ui>/hanaCount}" state="Information" class="sapUiTinyMarginEnd" />
					<ObjectStatus text="{i18n>statusMissing}: {ui>/missingCount}" state="{= ${ui>/missingCount} > 0 ? 'Error' : 'Success' }" />
					<Text text="{i18n>lastRefreshed}: {ui>/lastRefreshed}" class="sapUiSmallMarginBegin" />
				</f:actions>
			</f:DynamicPageTitle>
		</f:title>

		<!-- ====================== FILTER BAR (always visible) ====================== -->
		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<f:content>
					<!-- plain Toolbar (not OverflowToolbar) so controls never hide in a "..." overflow menu -->
					<Toolbar>
						<Label text="{i18n>masterDataLabel}" labelFor="msMaster" />
						<Select id="msMaster" selectedKey="{ui>/masterData}" change=".onMasterDataChange" width="12rem" autoAdjustWidth="false" class="sapUiSmallMarginEnd">
							<core:Item key="DELIVERY_ITEM" text="{i18n>mdDeliveryItem}" />
							<core:Item key="DELIVERY_HEADER" text="{i18n>mdDeliveryHeader}" />
							<core:Item key="SALES_HEADER" text="{i18n>mdSalesHeader}" />
							<core:Item key="SALES_ITEM" text="{i18n>mdSalesItem}" />
						</Select>
						<ToolbarSeparator />
						<Label text="{i18n>filterDateLabel}" labelFor="dpDate" />
						<DatePicker
							id="dpDate"
							value="{ui>/dateText}"
							valueFormat="yyyy-MM-dd"
							displayFormat="long"
							change=".onDateChange"
							enabled="{= ${ui>/masterData} === 'DELIVERY_ITEM' }"
							width="13rem"
							class="sapUiSmallMarginEnd" />
						<ToolbarSeparator />
						<Label text="{i18n>filterPlantLabel}" labelFor="selPlant" />
						<Select
							id="selPlant"
							selectedKey="{ui>/plant}"
							items="{ui>/plants}"
							change=".onLoad"
							enabled="{= ${ui>/masterData} === 'DELIVERY_ITEM' }"
							width="8rem"
							autoAdjustWidth="false"
							class="sapUiSmallMarginEnd">
							<core:Item key="{ui>key}" text="{ui>text}" />
						</Select>
						<Button
							id="btnRefresh"
							text="{i18n>btnLoad}"
							type="Emphasized"
							icon="sap-icon://synchronize"
							enabled="{= ${ui>/masterData} === 'DELIVERY_ITEM' }"
							press=".onLoad" />
						<ToolbarSpacer />
					</Toolbar>
				</f:content>
			</f:DynamicPageHeader>
		</f:header>

		<!-- ============================ CONTENT ============================ -->
		<f:content>
			<VBox fitContainer="true">

				<!-- Placeholder for master-data types that aren't wired up yet -->
				<IllustratedMessage
					visible="{= ${ui>/masterData} !== 'DELIVERY_ITEM' }"
					illustrationType="sapIllus-NoTasks"
					title="{i18n>comingSoonTitle}"
					description="{i18n>comingSoonText}"
					class="sapUiMediumMarginTop" />

				<!-- The live Delivery Item reconciliation. Grid tables (sap.ui.table)
				     are virtualized — only visible rows render, so 15k+ rows stay
				     smooth and selection/highlight act on the full dataset. -->
				<IconTabBar
					id="tabBar"
					visible="{= ${ui>/masterData} === 'DELIVERY_ITEM' }"
					selectedKey="{ui>/selectedTab}"
					select=".onTabSelect"
					expandable="false"
					stretchContentHeight="true"
					class="sapUiResponsiveContentPadding">
					<layoutData>
						<FlexItemData growFactor="1" />
					</layoutData>
					<items>

						<!-- ===================== ECC DATA ===================== -->
						<IconTabFilter id="tabEcc" key="ECC" icon="sap-icon://source-code" text="{i18n>tabEcc}" count="{ui>/eccCount}">
							<t:Table id="tblEcc" rows="{ecc>/items}" selectionMode="None" visibleRowCountMode="Auto" minAutoRowCount="5" enableColumnReordering="false" enableBusyIndicator="true">
								<t:extension>
									<OverflowToolbar>
										<Title text="{i18n>tabEcc}" level="H2" />
										<ToolbarSpacer />
										<SearchField width="18rem" search=".onSearch" placeholder="{i18n>searchPlaceholder}" />
									</OverflowToolbar>
								</t:extension>
								<t:columns>
									<t:Column width="9rem"><t:label><Label text="{i18n>colVbeln}" /></t:label><t:template><Text text="{ecc>Delivery_Delivery}" wrapping="false" /></t:template></t:Column>
									<t:Column width="7rem"><t:label><Label text="{i18n>colPosnr}" /></t:label><t:template><Text text="{ecc>Item}" wrapping="false" /></t:template></t:Column>
									<t:Column><t:label><Label text="{i18n>colMatnr}" /></t:label><t:template><Text text="{ecc>Material_Material}" wrapping="false" /></t:template></t:Column>
									<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>colLfimg}" /></t:label><t:template><ObjectNumber number="{ecc>DeliveryQuantity}" unit="{ecc>SalesUnit_UnitCode}" /></t:template></t:Column>
									<t:Column width="6rem"><t:label><Label text="{i18n>colVrkme}" /></t:label><t:template><Text text="{ecc>SalesUnit_UnitCode}" wrapping="false" /></t:template></t:Column>
									<t:Column width="7rem"><t:label><Label text="{i18n>colWerks}" /></t:label><t:template><Text text="{ecc>Plant}" wrapping="false" /></t:template></t:Column>
									<t:Column><t:label><Label text="{i18n>colLgort}" /></t:label><t:template><Text text="{ecc>StorageLocation}" wrapping="false" /></t:template></t:Column>
								</t:columns>
								<t:noData><Text text="{i18n>noDataEcc}" /></t:noData>
							</t:Table>
						</IconTabFilter>

						<!-- ===================== HANA DATA ===================== -->
						<IconTabFilter id="tabHana" key="HANA" icon="sap-icon://database" text="{i18n>tabHana}" count="{ui>/hanaCount}">
							<t:Table id="tblHana" rows="{hana>/items}" selectionMode="None" visibleRowCountMode="Auto" minAutoRowCount="5" enableColumnReordering="false" enableBusyIndicator="true">
								<t:extension>
									<OverflowToolbar>
										<Title text="{i18n>tabHana}" level="H2" />
										<ToolbarSpacer />
										<SearchField width="18rem" search=".onSearch" placeholder="{i18n>searchPlaceholder}" />
									</OverflowToolbar>
								</t:extension>
								<t:columns>
									<t:Column width="9rem"><t:label><Label text="{i18n>colVbeln}" /></t:label><t:template><Text text="{hana>Delivery_Delivery}" wrapping="false" /></t:template></t:Column>
									<t:Column width="7rem"><t:label><Label text="{i18n>colPosnr}" /></t:label><t:template><Text text="{hana>Item}" wrapping="false" /></t:template></t:Column>
									<t:Column><t:label><Label text="{i18n>colMatnr}" /></t:label><t:template><Text text="{hana>Material_Material}" wrapping="false" /></t:template></t:Column>
									<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>colLfimg}" /></t:label><t:template><ObjectNumber number="{hana>DeliveryQuantity}" unit="{hana>SalesUnit_UnitCode}" /></t:template></t:Column>
									<t:Column width="6rem"><t:label><Label text="{i18n>colVrkme}" /></t:label><t:template><Text text="{hana>SalesUnit_UnitCode}" wrapping="false" /></t:template></t:Column>
									<t:Column width="7rem"><t:label><Label text="{i18n>colWerks}" /></t:label><t:template><Text text="{hana>Plant}" wrapping="false" /></t:template></t:Column>
									<t:Column><t:label><Label text="{i18n>colLgort}" /></t:label><t:template><Text text="{hana>StorageLocation}" wrapping="false" /></t:template></t:Column>
								</t:columns>
								<t:noData><Text text="{i18n>noDataHana}" /></t:noData>
							</t:Table>
						</IconTabFilter>

						<!-- ===================== MISSING ITEMS ===================== -->
						<IconTabFilter id="tabMissing" key="MISSING" icon="sap-icon://alert" iconColor="{= ${ui>/missingCount} > 0 ? 'Negative' : 'Default' }" text="{i18n>tabMissing}" count="{ui>/missingCount}">
							<t:Table id="tblMissing" rows="{missing>/items}" selectionMode="MultiToggle" rowSelectionChange=".onMissingSelectionChange" visibleRowCountMode="Auto" minAutoRowCount="5" enableColumnReordering="false" enableBusyIndicator="true">
								<t:extension>
									<OverflowToolbar>
										<Title text="{i18n>tabMissing}" level="H2" />
										<ToolbarSpacer />
										<Text text="{i18n>selectedCount}: {ui>/selectedCount}" class="sapUiTinyMarginEnd" />
									</OverflowToolbar>
								</t:extension>
								<t:rowSettingsTemplate>
									<t:RowSettings highlight="{= ${missing>posted} ? 'Success' : (${missing>postError} ? 'Error' : 'None') }" />
								</t:rowSettingsTemplate>
								<t:columns>
									<t:Column width="9rem"><t:label><Label text="{i18n>colVbeln}" /></t:label><t:template><Text text="{missing>Delivery_Delivery}" wrapping="false" /></t:template></t:Column>
									<t:Column width="7rem"><t:label><Label text="{i18n>colPosnr}" /></t:label><t:template><Text text="{missing>Item}" wrapping="false" /></t:template></t:Column>
									<t:Column><t:label><Label text="{i18n>colMatnr}" /></t:label><t:template><Text text="{missing>Material_Material}" wrapping="false" /></t:template></t:Column>
									<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>colLfimg}" /></t:label><t:template><ObjectNumber number="{missing>DeliveryQuantity}" unit="{missing>SalesUnit_UnitCode}" /></t:template></t:Column>
									<t:Column width="6rem"><t:label><Label text="{i18n>colVrkme}" /></t:label><t:template><Text text="{missing>SalesUnit_UnitCode}" wrapping="false" /></t:template></t:Column>
									<t:Column width="7rem"><t:label><Label text="{i18n>colWerks}" /></t:label><t:template><Text text="{missing>Plant}" wrapping="false" /></t:template></t:Column>
									<t:Column><t:label><Label text="{i18n>colLgort}" /></t:label><t:template><Text text="{missing>StorageLocation}" wrapping="false" /></t:template></t:Column>
									<t:Column width="9rem" hAlign="Center"><t:label><Label text="{i18n>colStatus}" /></t:label>
										<t:template>
											<ObjectStatus
												text="{= ${missing>posted} ? ${i18n>statePosted} : (${missing>postError} ? ${i18n>stateFailed} : ${i18n>statePending}) }"
												state="{= ${missing>posted} ? 'Success' : (${missing>postError} ? 'Error' : 'Warning') }"
												icon="{= ${missing>posted} ? 'sap-icon://accept' : (${missing>postError} ? 'sap-icon://error' : 'sap-icon://pending') }" />
										</t:template>
									</t:Column>
								</t:columns>
								<t:noData><Text text="{i18n>noDataMissing}" /></t:noData>
							</t:Table>
						</IconTabFilter>

					</items>
				</IconTabBar>
			</VBox>
		</f:content>

		<!-- ====================== FOOTER (Missing tab only) ====================== -->
		<f:footer>
			<OverflowToolbar>
				<ToolbarSpacer />
				<Button id="btnSelectAll" text="{i18n>btnSelectAllPending}" icon="sap-icon://multi-select" press=".onSelectAllPending" />
				<Button id="btnPost" text="{i18n>btnPost} ({ui>/selectedCount})" type="Emphasized" icon="sap-icon://upload-to-cloud" enabled="{= ${ui>/selectedCount} > 0 }" press=".onPostSelected" />
			</OverflowToolbar>
		</f:footer>

	</f:DynamicPage>

</mvc:View>
