<mvc:View
	controllerName="com.bluestonex.cloudwmreconcilliationui.controller.Main"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:f="sap.f"
	displayBlock="true"
	height="100%">

	<f:DynamicPage id="page" showFooter="{= ${ui>/selectedTab} === 'MISSING' }" busy="{ui>/busy}" busyIndicatorDelay="0">

		<!-- ============================ TITLE ============================ -->
		<f:title>
			<f:DynamicPageTitle>
				<f:heading>
					<Title text="{i18n>appTitle}" />
				</f:heading>
				<f:snappedContent>
					<Text text="{i18n>filterDateLabel}: {ui>/dateText}" />
				</f:snappedContent>
				<f:actions>
					<ObjectStatus
						text="{i18n>statusEcc}: {ui>/eccCount}"
						state="Information"
						class="sapUiTinyMarginEnd" />
					<ObjectStatus
						text="{i18n>statusHana}: {ui>/hanaCount}"
						state="Information"
						class="sapUiTinyMarginEnd" />
					<ObjectStatus
						text="{i18n>statusMissing}: {ui>/missingCount}"
						state="{= ${ui>/missingCount} > 0 ? 'Error' : 'Success' }" />
				</f:actions>
			</f:DynamicPageTitle>
		</f:title>

		<!-- ============================ FILTER BAR ============================ -->
		<f:header>
			<f:DynamicPageHeader pinnable="true">
				<f:content>
					<OverflowToolbar>
						<Label text="{i18n>filterDateLabel}" labelFor="dpDate" />
						<DatePicker
							id="dpDate"
							value="{ui>/dateText}"
							valueFormat="yyyy-MM-dd"
							displayFormat="long"
							change=".onDateChange"
							class="sapUiSmallMarginEnd" />
						<Button
							id="btnRefresh"
							text="{i18n>btnLoad}"
							type="Emphasized"
							icon="sap-icon://synchronize"
							press=".onLoad" />
						<ToolbarSpacer />
						<Text text="{i18n>lastRefreshed}: {ui>/lastRefreshed}" />
					</OverflowToolbar>
				</f:content>
			</f:DynamicPageHeader>
		</f:header>

		<!-- ============================ TABS ============================ -->
		<f:content>
			<IconTabBar
				id="tabBar"
				selectedKey="{ui>/selectedTab}"
				select=".onTabSelect"
				expandable="false"
				stretchContentHeight="true"
				class="sapUiResponsiveContentPadding">

				<items>

					<!-- ===================== ECC DATA ===================== -->
					<IconTabFilter id="tabEcc" key="ECC" icon="sap-icon://source-code" text="{i18n>tabEcc}" count="{ui>/eccCount}">
						<Table
							id="tblEcc"
							items="{ecc>/items}"
							growing="true"
							growingThreshold="50"
							sticky="ColumnHeaders,HeaderToolbar"
							noDataText="{i18n>noDataEcc}">
							<headerToolbar>
								<OverflowToolbar>
									<Title text="{i18n>tabEcc}" level="H2" />
									<ToolbarSpacer />
									<SearchField width="18rem" search=".onSearch" placeholder="{i18n>searchPlaceholder}" />
									</OverflowToolbar>
								</headerToolbar>
							<columns>
								<Column><Text text="{i18n>colVbeln}" /></Column>
								<Column><Text text="{i18n>colPosnr}" /></Column>
								<Column><Text text="{i18n>colMatnr}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colArktx}" /></Column>
								<Column hAlign="End"><Text text="{i18n>colLfimg}" /></Column>
								<Column><Text text="{i18n>colVrkme}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colWerks}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLgort}" /></Column>
							</columns>
							<items>
								<ColumnListItem>
									<cells>
										<ObjectIdentifier title="{ecc>VBELN}" />
										<Text text="{ecc>POSNR}" />
										<Text text="{ecc>MATNR}" />
										<Text text="{ecc>ARKTX}" />
										<ObjectNumber number="{ecc>LFIMG}" unit="{ecc>VRKME}" />
										<Text text="{ecc>VRKME}" />
										<Text text="{ecc>WERKS}" />
										<Text text="{ecc>LGORT}" />
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</IconTabFilter>

					<!-- ===================== HANA DATA ===================== -->
					<IconTabFilter id="tabHana" key="HANA" icon="sap-icon://database" text="{i18n>tabHana}" count="{ui>/hanaCount}">
						<Table
							id="tblHana"
							items="{hana>/items}"
							growing="true"
							growingThreshold="50"
							sticky="ColumnHeaders,HeaderToolbar"
							noDataText="{i18n>noDataHana}">
							<headerToolbar>
								<OverflowToolbar>
									<Title text="{i18n>tabHana}" level="H2" />
									<ToolbarSpacer />
									<SearchField width="18rem" search=".onSearch" placeholder="{i18n>searchPlaceholder}" />
								</OverflowToolbar>
							</headerToolbar>
							<columns>
								<Column><Text text="{i18n>colVbeln}" /></Column>
								<Column><Text text="{i18n>colPosnr}" /></Column>
								<Column><Text text="{i18n>colMatnr}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colArktx}" /></Column>
								<Column hAlign="End"><Text text="{i18n>colLfimg}" /></Column>
								<Column><Text text="{i18n>colVrkme}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colWerks}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLgort}" /></Column>
							</columns>
							<items>
								<ColumnListItem>
									<cells>
										<ObjectIdentifier title="{hana>VBELN}" />
										<Text text="{hana>POSNR}" />
										<Text text="{hana>MATNR}" />
										<Text text="{hana>ARKTX}" />
										<ObjectNumber number="{hana>LFIMG}" unit="{hana>VRKME}" />
										<Text text="{hana>VRKME}" />
										<Text text="{hana>WERKS}" />
										<Text text="{hana>LGORT}" />
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</IconTabFilter>

					<!-- ===================== MISSING ITEMS ===================== -->
					<IconTabFilter id="tabMissing" key="MISSING" icon="sap-icon://alert" iconColor="{= ${ui>/missingCount} > 0 ? 'Negative' : 'Default' }" text="{i18n>tabMissing}" count="{ui>/missingCount}">
						<Table
							id="tblMissing"
							mode="MultiSelect"
							items="{missing>/items}"
							growing="true"
							growingThreshold="50"
							sticky="ColumnHeaders,HeaderToolbar"
							selectionChange=".onMissingSelectionChange"
							updateFinished=".onMissingTableUpdate"
							noDataText="{i18n>noDataMissing}">
							<headerToolbar>
								<OverflowToolbar>
									<Title text="{i18n>tabMissing}" level="H2" />
									<ToolbarSpacer />
									<Text text="{i18n>selectedCount}: {ui>/selectedCount}" class="sapUiTinyMarginEnd" />
								</OverflowToolbar>
							</headerToolbar>
							<columns>
								<Column><Text text="{i18n>colVbeln}" /></Column>
								<Column><Text text="{i18n>colPosnr}" /></Column>
								<Column><Text text="{i18n>colMatnr}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colArktx}" /></Column>
								<Column hAlign="End"><Text text="{i18n>colLfimg}" /></Column>
								<Column><Text text="{i18n>colVrkme}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colWerks}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>colLgort}" /></Column>
								<Column hAlign="Center"><Text text="{i18n>colStatus}" /></Column>
							</columns>
							<items>
								<ColumnListItem highlight="{= ${missing>posted} ? 'Success' : (${missing>postError} ? 'Error' : 'None') }">
									<cells>
										<ObjectIdentifier title="{missing>VBELN}" />
										<Text text="{missing>POSNR}" />
										<Text text="{missing>MATNR}" />
										<Text text="{missing>ARKTX}" />
										<ObjectNumber number="{missing>LFIMG}" unit="{missing>VRKME}" />
										<Text text="{missing>VRKME}" />
										<Text text="{missing>WERKS}" />
										<Text text="{missing>LGORT}" />
										<ObjectStatus
											text="{= ${missing>posted} ? ${i18n>statePosted} : (${missing>postError} ? ${i18n>stateFailed} : ${i18n>statePending}) }"
											state="{= ${missing>posted} ? 'Success' : (${missing>postError} ? 'Error' : 'Warning') }"
											icon="{= ${missing>posted} ? 'sap-icon://accept' : (${missing>postError} ? 'sap-icon://error' : 'sap-icon://pending') }" />
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</IconTabFilter>

				</items>
			</IconTabBar>
		</f:content>

		<!-- ============================ FOOTER (Missing tab only) ============================ -->
		<f:footer>
			<OverflowToolbar>
				<ToolbarSpacer />
				<Button
					id="btnSelectAll"
					text="{i18n>btnSelectAllPending}"
					icon="sap-icon://multi-select"
					press=".onSelectAllPending" />
				<Button
					id="btnPost"
					text="{i18n>btnPost} ({ui>/selectedCount})"
					type="Emphasized"
					icon="sap-icon://upload-to-cloud"
					enabled="{= ${ui>/selectedCount} > 0 }"
					press=".onPostSelected" />
			</OverflowToolbar>
		</f:footer>

	</f:DynamicPage>

</mvc:View>
