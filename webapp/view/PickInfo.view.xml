<mvc:View
	controllerName="com.bluestonex.cloudwmreconcilliationui.controller.PickInfo"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	displayBlock="true"
	height="100%">

	<Page title="{i18n>pickInfoTitle}" class="sapUiContentPadding">
		<content>
			<VBox class="sapUiSmallMargin">

				<!-- ===================== LOOKUP ===================== -->
				<Panel headerText="{i18n>pickLookupHeader}" width="auto">
					<HBox alignItems="End" wrap="Wrap" class="sapUiSmallMargin">
						<VBox class="sapUiSmallMarginEnd">
							<Label text="{i18n>pickModeLabel}" labelFor="pickMode" />
							<Select id="pickMode" selectedKey="{pick>/mode}" change=".onModeChange" width="16rem">
								<core:Item key="TASK" text="{i18n>pickModeTask}" />
								<core:Item key="LOGS" text="{i18n>pickModeLogs}" />
							</Select>
						</VBox>
						<VBox class="sapUiSmallMarginEnd">
							<Label text="{= ${pick>/mode} === 'LOGS' ? ${i18n>pickUserLabel} : ${i18n>pickNoLabel} }" labelFor="pickInput" />
							<Input
								id="pickInput"
								value="{pick>/query}"
								placeholder="{= ${pick>/mode} === 'LOGS' ? ${i18n>pickUserPlaceholder} : ${i18n>pickNoPlaceholder} }"
								submit=".onGetPick"
								width="20rem" />
						</VBox>
						<VBox class="sapUiSmallMarginEnd" visible="{= ${pick>/mode} === 'LOGS' }">
							<Label text="{i18n>pickDateLabel}" labelFor="pickDate" />
							<DatePicker id="pickDate" value="{pick>/date}" valueFormat="yyyy-MM-dd" displayFormat="long" width="13rem" />
						</VBox>
						<Button text="{i18n>btnGetPick}" type="Emphasized" icon="sap-icon://search" press=".onGetPick" />
					</HBox>
				</Panel>

				<!-- ===================== RESULTS ===================== -->
				<VBox busy="{pick>/busy}" busyIndicatorDelay="0">

					<!-- Pick Task header (bold, colour-coded status) -->
					<Panel headerText="{i18n>pickTaskResult}" width="auto" visible="{pick>/hasTask}" class="sapUiSmallMarginTop">
						<ObjectHeader
							icon="sap-icon://cart"
							responsive="true"
							title="{pick>/task/ID}"
							number="{pick>/task/TOTALCUBE}"
							numberUnit="m³">
							<statuses>
								<ObjectStatus
									title="{i18n>pickFldStatus}"
									text="{pick>/task/STATUS_ID}"
									state="{pick>/task/_statusState}"
									inverted="true" />
								<ObjectStatus
									title="{i18n>pickFldTemp}"
									text="{pick>/task/TEMPERATURE_ID}"
									icon="sap-icon://temperature"
									state="Information"
									inverted="true" />
							</statuses>
							<attributes>
								<ObjectAttribute title="{i18n>pickFldPlant}" text="{pick>/task/PLANT_PLANT}" />
								<ObjectAttribute title="{i18n>pickFldRoute}" text="{pick>/task/ROUTE}" />
								<ObjectAttribute title="{i18n>pickFldPlatform}" text="{pick>/task/DELIVERYPLATFORM_ROUTE}" />
								<ObjectAttribute title="{i18n>pickFldDelivery}" text="{pick>/task/DELIVERYDATE}" />
								<ObjectAttribute title="{i18n>pickFldType}" text="{pick>/task/PICKTYPE_ID}" />
								<ObjectAttribute title="{i18n>pickFldWeight}" text="{pick>/task/NOMINALWEIGHT}" />
								<ObjectAttribute title="{i18n>pickFldSeq}" text="{pick>/task/SEQUENCE}" />
								<ObjectAttribute title="{i18n>pickFldPicker}" text="{= ${pick>/task/PICKERUSERID} || '—' }" />
								<ObjectAttribute title="{i18n>pickFldPrepGroup}" text="{= ${pick>/task/PREPARATIONGROUP} || '—' }" />
								<ObjectAttribute title="{i18n>pickFldCreated}" text="{pick>/task/CREATEDBY}" />
							</attributes>
						</ObjectHeader>
					</Panel>

					<!-- Picker activity for the chosen day, consolidated per pick task -->
					<Panel headerText="{i18n>pickLogsResult}" width="auto" visible="{pick>/hasLogs}" class="sapUiSmallMarginTop">
						<OverflowToolbar>
							<ObjectStatus text="{i18n>pickUserLabel}: {pick>/summary/user}" class="sapUiTinyMarginEnd" />
							<ToolbarSpacer />
							<ObjectStatus text="{i18n>pickEvents}: {pick>/summary/events}" state="Information" inverted="true" class="sapUiTinyMarginEnd" />
							<ObjectStatus text="{i18n>pickTasks}: {pick>/summary/tasks}" state="Information" inverted="true" class="sapUiTinyMarginEnd" />
							<ObjectStatus text="{i18n>pickCompleted}: {pick>/summary/completed}" state="Success" inverted="true" />
						</OverflowToolbar>
						<Table
							id="logsTable"
							items="{ path: 'pick>/logs', sorter: [ { path: 'PICKTASK_ID', descending: true, group: true }, { path: 'EVENT_TIMESTAMP', descending: true } ] }"
							growing="true"
							growingThreshold="200"
							sticky="ColumnHeaders,HeaderToolbar,GroupHeaders"
							noDataText="{i18n>pickNoResult}">
							<headerToolbar>
								<OverflowToolbar>
									<Title text="{i18n>pickLogsResult}" level="H3" />
									<ToolbarSpacer />
									<SearchField width="18rem" search=".onLogSearch" placeholder="{i18n>pickLogSearch}" />
								</OverflowToolbar>
							</headerToolbar>
							<columns>
								<Column><Text text="{i18n>pickColTime}" /></Column>
								<Column><Text text="{i18n>pickColEvent}" /></Column>
								<Column minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>pickColItem}" /></Column>
								<Column hAlign="End"><Text text="{i18n>pickColQty}" /></Column>
								<Column hAlign="Center" minScreenWidth="Tablet" demandPopin="true"><Text text="{i18n>pickColLevel}" /></Column>
							</columns>
							<items>
								<ColumnListItem>
									<cells>
										<Text text="{pick>_ts}" />
										<ObjectStatus text="{pick>_event}" state="{pick>_state}" />
										<Text text="{pick>ITEM_ID}" />
										<ObjectNumber number="{pick>QUANTITY}" />
										<Text text="{pick>_level}" />
									</cells>
								</ColumnListItem>
							</items>
						</Table>
					</Panel>

					<!-- Empty state: animated warehouse-picker illustration -->
					<VBox visible="{= !${pick>/hasTask} &amp;&amp; !${pick>/hasLogs} }" alignItems="Center" class="sapUiMediumMarginTop">
						<Image src="{pick>/artUrl}" width="20rem" densityAware="false" />
						<Title text="{i18n>pickEmptyTitle}" level="H2" class="sapUiSmallMarginTop" />
						<Text text="{i18n>pickEmpty}" textAlign="Center" class="sapUiTinyMarginTop" />
					</VBox>

				</VBox>

			</VBox>
		</content>
	</Page>

</mvc:View>
