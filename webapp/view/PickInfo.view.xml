<mvc:View
	controllerName="com.bluestonex.cloudwmreconcilliationui.controller.PickInfo"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	displayBlock="true"
	height="100%">

	<Page title="{i18n>pickInfoTitle}" class="sapUiContentPadding">
		<content>
			<VBox class="sapUiSmallMargin">

				<!-- ===================== LOOKUP ===================== -->
				<Panel headerText="{i18n>pickLookupHeader}" width="auto">
					<HBox alignItems="End" wrap="Wrap" class="sapUiSmallMargin">
						<VBox class="sapUiSmallMarginEnd">
							<Label text="{i18n>pickNoLabel}" labelFor="pickInput" />
							<Input
								id="pickInput"
								value="{pick>/query}"
								placeholder="{i18n>pickNoPlaceholder}"
								submit=".onGetPick"
								width="20rem" />
						</VBox>
						<Button text="{i18n>btnGetPick}" type="Emphasized" icon="sap-icon://search" press=".onGetPick" />
					</HBox>
				</Panel>

				<!-- ===================== RESULTS ===================== -->
				<VBox busy="{pick>/busy}" busyIndicatorDelay="0">

					<!-- Pick Task header (bold, colour-coded status) -->
					<Panel headerText="{i18n>pickTaskResult}" width="auto" visible="{pick>/hasTask}" class="sapUiSmallMarginTop">
						<ObjectHeader
							icon="sap-icon://cart"
							responsive="true"
							title="{pick>/task/ID}"
							number="{pick>/task/TOTALCUBE}"
							numberUnit="m³">
							<statuses>
								<ObjectStatus title="{i18n>pickFldStatus}" text="{pick>/task/STATUS_ID}" state="{pick>/task/_statusState}" inverted="true" />
								<ObjectStatus title="{i18n>pickFldTemp}" text="{pick>/task/TEMPERATURE_ID}" icon="sap-icon://temperature" state="Information" inverted="true" />
							</statuses>
							<attributes>
								<ObjectAttribute title="{i18n>pickFldPlant}" text="{pick>/task/PLANT_PLANT}" />
								<ObjectAttribute title="{i18n>pickFldRoute}" text="{pick>/task/ROUTE}" />
								<ObjectAttribute title="{i18n>pickFldPlatform}" text="{pick>/task/DELIVERYPLATFORM_ROUTE}" />
								<ObjectAttribute title="{i18n>pickFldDelivery}" text="{pick>/task/DELIVERYDATE}" />
								<ObjectAttribute title="{i18n>pickFldType}" text="{pick>/task/PICKTYPE_ID}" />
								<ObjectAttribute title="{i18n>pickFldWeight}" text="{pick>/task/NOMINALWEIGHT}" />
								<ObjectAttribute title="{i18n>pickFldSeq}" text="{pick>/task/SEQUENCE}" />
								<ObjectAttribute title="{i18n>pickFldPicker}" text="{= ${pick>/task/PICKERUSERID} || '—' }" />
								<ObjectAttribute title="{i18n>pickFldPrepGroup}" text="{= ${pick>/task/PREPARATIONGROUP} || '—' }" />
								<ObjectAttribute title="{i18n>pickFldCreated}" text="{pick>/task/CREATEDBY}" />
							</attributes>
						</ObjectHeader>
					</Panel>

					<!-- Pick Task items — full field set in a virtualized grid (horizontal
					     scroll for the many columns; reorder/freeze enabled). -->
					<Panel headerText="{i18n>pickItemsHeader}" width="auto" visible="{pick>/hasTask}" class="sapUiSmallMarginTop">
						<t:Table id="itemsTable" rows="{pick>/items}" selectionMode="None" visibleRowCountMode="Fixed" visibleRowCount="8" enableColumnReordering="true" enableColumnFreeze="true">
							<t:columns>
								<t:Column width="13rem"><t:label><Label text="{i18n>pickItemMaterial}" /></t:label><t:template><Text text="{pick>MATERIAL_MATERIAL}" wrapping="false" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>pickItemTotalQty}" /></t:label><t:template><ObjectNumber number="{pick>TOTALQUANTITY}" unit="{pick>UOM_UNITCODE}" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>pickItemOpenQty}" /></t:label><t:template><ObjectNumber number="{pick>OPENQUANTITY}" unit="{pick>UOM_UNITCODE}" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>pickItemPalletisedQty}" /></t:label><t:template><Text text="{pick>PALLETISEDQUANTITY}" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>pickItemDecantedQty}" /></t:label><t:template><Text text="{pick>DECANTEDQUANTITY}" /></t:template></t:Column>
								<t:Column width="5rem"><t:label><Label text="{i18n>pickItemUom}" /></t:label><t:template><Text text="{pick>UOM_UNITCODE}" /></t:template></t:Column>
								<t:Column width="6rem" hAlign="End"><t:label><Label text="{i18n>pickItemNumerator}" /></t:label><t:template><Text text="{pick>NUMERATORFORCASE}" /></t:template></t:Column>
								<t:Column width="6rem" hAlign="End"><t:label><Label text="{i18n>pickItemDenominator}" /></t:label><t:template><Text text="{pick>DENOMINATORFORCASE}" /></t:template></t:Column>
								<t:Column width="8rem"><t:label><Label text="{i18n>pickItemBatch}" /></t:label><t:template><Text text="{pick>BATCH}" /></t:template></t:Column>
								<t:Column width="5rem"><t:label><Label text="{i18n>pickItemSLoc}" /></t:label><t:template><Text text="{pick>SLOC}" /></t:template></t:Column>
								<t:Column width="7rem"><t:label><Label text="{i18n>pickItemWarehouse}" /></t:label><t:template><Text text="{pick>WAREHOUSE_WAREHOUSENUMBER}" /></t:template></t:Column>
								<t:Column width="9rem"><t:label><Label text="{i18n>pickItemBin}" /></t:label><t:template><Text text="{pick>SOURCESTORAGEBIN}" /></t:template></t:Column>
								<t:Column width="6rem"><t:label><Label text="{i18n>pickItemStorageType}" /></t:label><t:template><Text text="{pick>SOURCESTORAGETYPE}" /></t:template></t:Column>
								<t:Column width="6rem" hAlign="End"><t:label><Label text="{i18n>pickItemPosition}" /></t:label><t:template><Text text="{pick>POSITIONINCAGE}" /></t:template></t:Column>
								<t:Column width="5rem" hAlign="End"><t:label><Label text="{i18n>pickItemDrop}" /></t:label><t:template><Text text="{pick>DROP}" /></t:template></t:Column>
								<t:Column width="8rem"><t:label><Label text="{i18n>pickItemShipTo}" /></t:label><t:template><Text text="{pick>SHIPTO}" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>pickItemNominalWeight}" /></t:label><t:template><Text text="{pick>NOMINALWEIGHT}" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="End"><t:label><Label text="{i18n>pickItemActualWeight}" /></t:label><t:template><Text text="{pick>ACTUALWEIGHT}" /></t:template></t:Column>
								<t:Column width="7rem" hAlign="End"><t:label><Label text="{i18n>pickItemCube}" /></t:label><t:template><Text text="{pick>CUBE}" /></t:template></t:Column>
								<t:Column width="8rem"><t:label><Label text="{i18n>pickItemPickSeq}" /></t:label><t:template><Text text="{pick>PICKSEQUENCE}" /></t:template></t:Column>
								<t:Column width="10rem"><t:label><Label text="{i18n>pickItemLabel}" /></t:label><t:template><Text text="{pick>PICKSTICKLABELID}" /></t:template></t:Column>
								<t:Column width="9rem"><t:label><Label text="{i18n>pickItemFinalPallet}" /></t:label><t:template><Text text="{pick>FINALPALLETID}" /></t:template></t:Column>
								<t:Column width="8rem"><t:label><Label text="{i18n>pickItemPackBox}" /></t:label><t:template><Text text="{pick>PACKBOXTYPE_PACKBOXTYPE}" /></t:template></t:Column>
								<t:Column width="6rem" hAlign="Center"><t:label><Label text="{i18n>pickItemShort}" /></t:label><t:template><Text text="{= ${pick>ISSHORT} ? 'Yes' : 'No' }" /></t:template></t:Column>
								<t:Column width="9rem"><t:label><Label text="{i18n>pickItemShortReason}" /></t:label><t:template><Text text="{pick>SHORTREASONCODE_CODE}" /></t:template></t:Column>
								<t:Column width="6rem" hAlign="Center"><t:label><Label text="{i18n>pickItemCase}" /></t:label><t:template><Text text="{= ${pick>ISCASE} ? 'Yes' : 'No' }" /></t:template></t:Column>
								<t:Column width="8rem" hAlign="Center"><t:label><Label text="{i18n>pickItemReplen}" /></t:label><t:template><Text text="{= ${pick>ISREPLENCOMPLETED} ? 'Yes' : 'No' }" /></t:template></t:Column>
								<t:Column width="10rem"><t:label><Label text="{i18n>pickItemStatus}" /></t:label><t:template><ObjectStatus text="{pick>STATUS_ID}" state="{= ${pick>STATUS_ID} === 'COMPLETED' ? 'Success' : 'Information' }" /></t:template></t:Column>
							</t:columns>
							<t:noData><Text text="{i18n>pickItemsNoData}" /></t:noData>
						</t:Table>
					</Panel>

					<!-- Empty state: animated warehouse-picker illustration -->
					<VBox visible="{= !${pick>/hasTask} }" alignItems="Center" class="sapUiMediumMarginTop">
						<Image src="{pick>/artUrl}" width="20rem" densityAware="false" />
						<Title text="{i18n>pickEmptyTitle}" level="H2" class="sapUiSmallMarginTop" />
						<Text text="{i18n>pickEmpty}" textAlign="Center" class="sapUiTinyMarginTop" />
					</VBox>

				</VBox>

			</VBox>
		</content>
	</Page>

</mvc:View>
