<mvc:View
	controllerName="com.bluestonex.cloudwmreconcilliationui.controller.PickInfo"
	xmlns="sap.m"
	xmlns:mvc="sap.ui.core.mvc"
	xmlns:core="sap.ui.core"
	xmlns:t="sap.ui.table"
	displayBlock="true"
	height="100%">

	<Page title="{i18n>pickInfoTitle}" class="sapUiContentPadding">
		<content>
			<VBox class="sapUiSmallMargin">

				<!-- ===================== LOOKUP ===================== -->
				<Panel headerText="{i18n>pickLookupHeader}" width="auto">
					<HBox alignItems="End" wrap="Wrap" class="sapUiSmallMargin">
						<VBox class="sapUiSmallMarginEnd">
							<Label text="{i18n>pickModeLabel}" labelFor="pickMode" />
							<Select id="pickMode" selectedKey="{pick>/mode}" change=".onModeChange" width="16rem">
								<core:Item key="TASK" text="{i18n>pickModeTask}" />
							</Select>
						</VBox>
						<VBox class="sapUiSmallMarginEnd">
							<Label text="{= ${pick>/mode} === 'LOGS' ? ${i18n>pickUserLabelOpt} : ${i18n>pickNoLabel} }" labelFor="pickInput" />
							<Input
								id="pickInput"
								value="{pick>/query}"
								placeholder="{= ${pick>/mode} === 'LOGS' ? ${i18n>pickUserPlaceholder} : ${i18n>pickNoPlaceholder} }"
								submit=".onGetPick"
								width="20rem" />
						</VBox>
						<VBox class="sapUiSmallMarginEnd" visible="{= ${pick>/mode} === 'LOGS' }">
							<Label text="{i18n>pickDateLabel}" labelFor="pickDate" />
							<DatePicker id="pickDate" value="{pick>/date}" valueFormat="yyyy-MM-dd" displayFormat="long" width="13rem" />
						</VBox>
						<Button text="{i18n>btnGetPick}" type="Emphasized" icon="sap-icon://search" press=".onGetPick" />
					</HBox>
				</Panel>

				<!-- ===================== RESULTS ===================== -->
				<VBox busy="{pick>/busy}" busyIndicatorDelay="0">

					<!-- Pick Task header (bold, colour-coded status) -->
					<Panel headerText="{i18n>pickTaskResult}" width="auto" visible="{pick>/hasTask}" class="sapUiSmallMarginTop">
						<ObjectHeader
							icon="sap-icon://cart"
							responsive="true"
							title="{pick>/task/ID}"
							number="{pick>/task/TOTALCUBE}"
							numberUnit="m³">
							<statuses>
								<ObjectStatus title="{i18n>pickFldStatus}" text="{pick>/task/STATUS_ID}" state="{pick>/task/_statusState}" inverted="true" />
								<ObjectStatus title="{i18n>pickFldTemp}" text="{pick>/task/TEMPERATURE_ID}" icon="sap-icon://temperature" state="Information" inverted="true" />
							</statuses>
							<attributes>
								<ObjectAttribute title="{i18n>pickFldPlant}" text="{pick>/task/PLANT_PLANT}" />
								<ObjectAttribute title="{i18n>pickFldRoute}" text="{pick>/task/ROUTE}" />
								<ObjectAttribute title="{i18n>pickFldPlatform}" text="{pick>/task/DELIVERYPLATFORM_ROUTE}" />
								<ObjectAttribute title="{i18n>pickFldDelivery}" text="{pick>/task/DELIVERYDATE}" />
								<ObjectAttribute title="{i18n>pickFldType}" text="{pick>/task/PICKTYPE_ID}" />
								<ObjectAttribute title="{i18n>pickFldWeight}" text="{pick>/task/NOMINALWEIGHT}" />
								<ObjectAttribute title="{i18n>pickFldSeq}" text="{pick>/task/SEQUENCE}" />
								<ObjectAttribute title="{i18n>pickFldPicker}" text="{= ${pick>/task/PICKERUSERID} || '—' }" />
								<ObjectAttribute title="{i18n>pickFldPrepGroup}" text="{= ${pick>/task/PREPARATIONGROUP} || '—' }" />
								<ObjectAttribute title="{i18n>pickFldCreated}" text="{pick>/task/CREATEDBY}" />
							</attributes>
						</ObjectHeader>
					</Panel>

					<!-- Picker activity: User -> Picks -> Events tree -->
					<Panel width="auto" visible="{pick>/hasLogs}" class="sapUiSmallMarginTop">

						<!-- report-style summary header -->
						<VBox class="sapUiSmallMarginBegin sapUiSmallMarginTop">
							<HBox alignItems="Center">
								<core:Icon src="sap-icon://group" class="sapUiTinyMarginEnd" />
								<Title id="pickLogsTitle" text="{i18n>pickLogsResult} — {pick>/summary/date}" level="H3" />
							</HBox>
							<HBox wrap="Wrap" alignItems="Center" class="sapUiTinyMarginTop">
								<ObjectStatus text="{pick>/summary/scope}" class="sapUiTinyMarginEnd" />
								<ObjectStatus text="{pick>/summary/tasks} {i18n>pickTasks}" state="Information" inverted="true" class="sapUiTinyMarginEnd" />
								<ObjectStatus text="{pick>/summary/events} {i18n>pickEvents}" state="Information" inverted="true" class="sapUiTinyMarginEnd" />
								<ObjectStatus text="{pick>/summary/completed} {i18n>pickCompleted}" state="Success" inverted="true" class="sapUiTinyMarginEnd" />
								<ObjectStatus text="{pick>/summary/from}–{pick>/summary/to}" icon="sap-icon://history" />
							</HBox>
						</VBox>

						<t:TreeTable
							id="logsTable"
							class="bsxZebra"
							rows="{ path: 'pick>/tree', parameters: { arrayNames: ['children'] } }"
							selectionMode="None"
							visibleRowCount="16"
							numberOfExpandedLevels="1"
							enableColumnReordering="false"
							ariaLabelledBy="pickLogsTitle">
							<t:extension>
								<OverflowToolbar>
									<ToolbarSpacer />
									<SearchField width="16rem" liveChange=".onLogSearch" search=".onLogSearch" placeholder="{i18n>pickLogSearch}" />
									<Button text="{i18n>pickExport}" icon="sap-icon://excel-attachment" press=".onExportExcel" />
								</OverflowToolbar>
							</t:extension>
							<t:columns>
								<t:Column width="20rem">
									<t:label><Label text="{i18n>pickColPickTime}" /></t:label>
									<t:template>
										<Text text="{= ${pick>isUser} ? ${pick>USER_ID} : (${pick>isPick} ? ${pick>PICKTASK_ID} : ${pick>_ts}) }" wrapping="false" />
									</t:template>
								</t:Column>
								<t:Column width="16rem">
									<t:label><Label text="{i18n>pickColEvent}" /></t:label>
									<t:template>
										<ObjectStatus text="{pick>_event}" state="{pick>_state}" inverted="{= !!${pick>isUser} || !!${pick>isPick} }" />
									</t:template>
								</t:Column>
								<t:Column>
									<t:label><Label text="{i18n>pickColItem}" /></t:label>
									<t:template>
										<Text text="{pick>ITEM_ID}" wrapping="false" />
									</t:template>
								</t:Column>
								<t:Column width="7rem" hAlign="End">
									<t:label><Label text="{i18n>pickColQty}" /></t:label>
									<t:template>
										<Text text="{pick>QUANTITY}" />
									</t:template>
								</t:Column>
								<t:Column width="8rem">
									<t:label><Label text="{i18n>pickColLevel}" /></t:label>
									<t:template>
										<Text text="{pick>_level}" />
									</t:template>
								</t:Column>
							</t:columns>
						</t:TreeTable>
					</Panel>

					<!-- Empty state: animated warehouse-picker illustration -->
					<VBox visible="{= !${pick>/hasTask} &amp;&amp; !${pick>/hasLogs} }" alignItems="Center" class="sapUiMediumMarginTop">
						<Image src="{pick>/artUrl}" width="20rem" densityAware="false" />
						<Title text="{i18n>pickEmptyTitle}" level="H2" class="sapUiSmallMarginTop" />
						<Text text="{i18n>pickEmpty}" textAlign="Center" class="sapUiTinyMarginTop" />
					</VBox>

				</VBox>

			</VBox>
		</content>
	</Page>

</mvc:View>
