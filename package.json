{
  "name": "cloudwmreconcilliationui",
  "version": "1.0.0",
  "description": "Freestyle SAPUI5 reconciliation monitor for the SAP LIPS delivery-item table (ECC vs HANA)",
  "private": true,
  "sapux": true,
  "keywords": [
    "ui5",
    "sapui5",
    "fiori",
    "freestyle",
    "lips",
    "reconciliation"
  ],
  "main": "webapp/index.html",
  "scripts": {
    "start": "ui5 serve --open index.html",
    "start-noflp": "ui5 serve --open index.html",
    "build": "ui5 build --clean-dest --dest dist",
    "lint": "echo \"Add eslint here if desired\"",
    "build:cf": "ui5 build preload --clean-dest --config ui5-deploy.yaml --include-task=generateCachebusterInfo",
    "build:mta": "rimraf resources mta_archives && mbt build",
    "deploy": "fiori cfDeploy",
    "undeploy": "cf undeploy combluestonexcloudwmreconcilliationui --delete-services --delete-service-keys --delete-service-brokers"
  },
  "devDependencies": {
    "@ui5/cli": "^3.11.0",
    "@sap/ux-ui5-tooling": "^1.15.4",
    "ui5-task-zipper": "^3.4.x",
    "rimraf": "^5.0.5",
    "mbt": "^1.2.49"
  },
  "ui5": {
    "dependencies": [
      "@sap/ux-ui5-tooling"
    ]
  }
}
